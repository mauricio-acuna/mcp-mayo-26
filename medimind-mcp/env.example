# ==========================================
# MediMind MCP - Environment Configuration
# ⚠️ NEVER COMMIT THIS FILE WITH REAL VALUES!
# ==========================================

# ==========================================
# Environment
# ==========================================
ENVIRONMENT=development
DEBUG=False

# ==========================================
# Database (ENCRYPTED!)
# ==========================================
# PostgreSQL with SSL required
DATABASE_URL=postgresql://medimind:CHANGE_ME@localhost:5432/medimind?sslmode=require

# MongoDB with authentication
MONGODB_URL=mongodb://medimind:CHANGE_ME@localhost:27017/medimind?authSource=admin

# Redis with password
REDIS_URL=redis://:CHANGE_ME@localhost:6379/0

# ==========================================
# FHIR Server (Epic Sandbox)
# ==========================================
# Register at: https://fhir.epic.com/Developer/Apps
FHIR_BASE_URL=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4
FHIR_CLIENT_ID=your_epic_sandbox_client_id
FHIR_CLIENT_SECRET=your_epic_sandbox_client_secret
FHIR_REDIRECT_URI=http://localhost:8000/auth/fhir/callback

# ==========================================
# External APIs (DEVELOPMENT - No keys yet)
# ==========================================
# PubMed API: https://www.ncbi.nlm.nih.gov/account/
PUBMED_API_KEY=development_placeholder

# DrugBank API: https://go.drugbank.com/
DRUGBANK_API_KEY=development_placeholder

# UpToDate (Optional)
UPTODATE_API_KEY=

# ==========================================
# Security (GENERATE THESE!)
# ==========================================
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=GENERATE_ME_WITH_FERNET

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=GENERATE_ME_WITH_SECRETS

# AWS KMS (Production only)
AWS_KMS_KEY_ID=

# ==========================================
# HIPAA Compliance
# ==========================================
PHI_ENCRYPTION_ENABLED=True
AUDIT_LOG_RETENTION_DAYS=2555
SESSION_TIMEOUT_MINUTES=15
BREACH_NOTIFICATION_EMAIL=security@yourhospital.com

# ==========================================
# AI Models
# ==========================================
MODEL_PATH=./models
BIOGPT_MODEL=microsoft/biogpt
SCISPACY_MODEL=en_core_sci_lg
